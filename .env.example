# CorpAI – example environment variables for local development
# Copy this file to .env and fill in your values

# ── LLM Gateway ──────────────────────────────────────────────────────────────
# Required: OpenAI API key (or leave as placeholder to disable LLM calls)
OPENAI_API_KEY=sk-your-openai-api-key-here

# Optional: Azure OpenAI (set llm.strategy=azure-openai to use instead of OpenAI)
AZURE_OPENAI_ENDPOINT=
AZURE_OPENAI_KEY=
AZURE_OPENAI_DEPLOYMENT=gpt-4

# ── JWT / Authentication ──────────────────────────────────────────────────────
# Keycloak (or compatible) issuer URI – used in .env.example for reference
JWT_ISSUER_URI=http://localhost:8088/realms/corpai
# JWK Set URI used by the Gateway to validate JWT tokens (lazy – gateway starts without Keycloak)
JWT_JWK_SET_URI=http://localhost:8088/realms/corpai/protocol/openid-connect/certs

# ── Keycloak (Docker Compose) ─────────────────────────────────────────────────
# Admin credentials for the Keycloak container (development only; change for any non-local env)
KEYCLOAK_ADMIN=admin
KEYCLOAK_ADMIN_PASSWORD=admin

# ── Database (PostgreSQL) ─────────────────────────────────────────────────────
DB_HOST=localhost
DB_PORT=5432
DB_NAME=corpai
DB_USER=corpai
DB_PASSWORD=corpai_secret

# ── Redis ─────────────────────────────────────────────────────────────────────
REDIS_HOST=localhost
REDIS_PORT=6379

# ── Kafka ─────────────────────────────────────────────────────────────────────
KAFKA_BOOTSTRAP_SERVERS=localhost:9092

# ── Gateway – downstream service hosts ───────────────────────────────────────
# Defaults to localhost (local dev). Override with Docker service names when
# running inside Docker Compose (e.g. ORCHESTRATOR_HOST=corpai-orchestrator).
ORCHESTRATOR_HOST=localhost
COMPANY_PROFILE_HOST=localhost
FINANCIAL_ANALYSIS_HOST=localhost
AML_KYC_HOST=localhost
SALES_INSIGHT_HOST=localhost
REPORT_GENERATOR_HOST=localhost
NOTIFICATION_HOST=localhost

# ── Notification Service ──────────────────────────────────────────────────────
# Optional: outbound SMTP for advisor email notifications
MAIL_HOST=smtp.pkobp.pl
MAIL_PORT=587
MAIL_USERNAME=corpai-noreply@pkobp.pl
MAIL_PASSWORD=
